# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.production on your production server
# IMPORTANT: Generate new secrets - DO NOT use development values in production
# =============================================================================

# Supabase Configuration (from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# Database (PostgreSQL via Supabase - Production)
DATABASE_URL=postgresql://postgres:your_secure_password@db.your-project.supabase.co:5432/postgres

# Paystack Configuration (PRODUCTION KEYS - get from Paystack dashboard)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key
PAYSTACK_SECRET_KEY=sk_live_your_live_secret_key

# Currency Exchange API (get production key)
EXCHANGE_RATE_API_KEY=your_production_exchange_api_key

# Resend Email Service (Production API key)
RESEND_API_KEY=re_your_production_resend_key

# Admin Email for Contact Form (Production)
ADMIN_EMAIL=admin@yourdomain.com

# Application Settings (CRITICAL FOR PRODUCTION)
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
NODE_ENV=production

# Admin Authentication (MUST GENERATE NEW SECRET)
# Generate with: openssl rand -base64 64
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
ADMIN_AUTH_JWT_SECRET=GENERATE_A_NEW_64_CHARACTER_SECRET_HERE_DO_NOT_USE_DEV_SECRET

# Rate Limiting (Optional - for additional security)
# RATE_LIMIT_MAX_REQUESTS=5
# RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# SECURITY CHECKLIST BEFORE DEPLOYMENT:
# =============================================================================
# ✅ 1. Generated new ADMIN_AUTH_JWT_SECRET (DO NOT use dev secret)
# ✅ 2. Using Paystack LIVE keys (pk_live_... and sk_live_...)
# ✅ 3. NEXT_PUBLIC_APP_URL points to production domain (HTTPS)
# ✅ 4. NODE_ENV set to "production"
# ✅ 5. Database using production credentials with strong password
# ✅ 6. All API keys are production keys, not test keys
# ✅ 7. Firewall rules configured on hosting platform
# ✅ 8. SSL/TLS certificate installed (HTTPS enforced)
# ✅ 9. Run: npx prisma migrate deploy (if using Prisma)
# ✅ 10. Run session management SQL script on production database
# =============================================================================
